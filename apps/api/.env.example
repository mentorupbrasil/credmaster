# ==========================================================================
#  CredMaster API - Template de variáveis de ambiente
#  Copie para `.env` e preencha com valores reais.
# ==========================================================================

NODE_ENV=development
PORT=3333
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000
# URL pública do front (usada nos links de e-mail de verificação/reset)
WEB_URL=http://localhost:3000

# --- Banco de dados (PostgreSQL / Neon) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Autenticação JWT (gere segredos fortes: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Segurança / Rate limit ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- Job diário de cobrança ---
COBRANCA_CRON=5 0 * * *
TIMEZONE=America/Sao_Paulo

# --- E-mail / observabilidade ---
MAIL_FROM=no-reply@credmaster.local
# SENTRY_DSN= (opcional; se definido, ativa o Sentry)

# --- Parâmetros regulatórios padrão ---
PARAM_MULTA_MAX_PERCENT=2
PARAM_JUROS_MORA_MAX_MES_PERCENT=1
PARAM_TAXA_JUROS_MAX_MES_PERCENT=12
PARAM_VALOR_MIN_GLOBAL=100
PARAM_VALOR_MAX_GLOBAL=1000000
PARAM_PRAZO_MIN_GLOBAL=1
PARAM_PRAZO_MAX_GLOBAL=120
PARAM_IOF_DIARIO_PERCENT=0.0082
PARAM_IOF_ADICIONAL_PERCENT=0.38
