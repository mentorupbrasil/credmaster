{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npm run vercel-build",
  "crons": [
    {
      "path": "/api/v1/cron/cobranca",
      "schedule": "5 0 * * *"
    }
  ],
  "functions": {
    "pages/api/[[...path]].ts": {
      "maxDuration": 60,
      "includeFiles": ".api-dist/**"
    }
  }
}
